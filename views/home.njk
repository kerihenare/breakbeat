{% extends "layout.njk" %}
{% block content %}
<div class="lg:grid lg:grid-cols-[320px_1fr] lg:h-[calc(100vh-57px)]">
	{% include "_search_rail.njk" %}

	<!-- Results pane -->
	<section id="results" class="p-6 lg:overflow-y-auto">
		<div class="max-w-prose mt-12 mx-auto">
			<h1 class="text-lg font-semibold text-ink m-0">See who's talking about a company</h1>
			<p class="text-text-muted mt-2">
				Enter a company name and homepage URL on the left. Breakbeat searches the last 36 months
				and groups what it finds by type: news, trade press, press releases, podcasts, blog posts,
				newsletters, and social posts, each one linked to its original source.
			</p>
			<p class="text-text-muted mt-2">
				Coverage from the company's own channels, aggregators, and store pages is filtered out and
				listed separately, so what's left is what others are saying.
			</p>
		</div>
	</section>
</div>
{% endblock %}
