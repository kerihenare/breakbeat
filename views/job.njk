{% extends "layout.njk" %}
{% block title %}{{ view.companyName }} — Breakbeat{% endblock %}
{% block content %}
<div class="lg:grid lg:grid-cols-[320px_1fr] lg:h-[calc(100vh-57px)]">
	{% include "_search_rail.njk" %}

	<!-- Results pane: same #results container the rail targets, so search and
	     recent-job navigation behave identically to the home page. -->
