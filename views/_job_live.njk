{# Wrapper: the swappable pane + a one-shot SSE connector. SSE swaps only the
   inner #job-pane, so this script is never re-run by an update. #}
<div id="job-pane">{% include "_job_pane.njk" %}</div>
{% if not view.isTerminal %}
<script>
(function () {
	var es = new EventSource("/jobs/{{ view.id }}/events");
	es.addEventListener("message", function (e) {
		var pane = document.getElementById("job-pane");
		if (pane) pane.innerHTML = e.data;
	});
	es.addEventListener("done", function () { es.close(); });
})();
</script>
{% endif %}
