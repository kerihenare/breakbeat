# --- App ---
NODE_ENV=development
PORT=3000

# --- Backing services ---
# Host-oriented defaults (for `pnpm dev` on the host). docker-compose overrides
# these per-service with the in-network service names (postgres/redis/victorialogs).
DATABASE_URL=postgres://breakbeat:breakbeat@localhost:5432/breakbeat
REDIS_URL=redis://localhost:6379
VICTORIALOGS_URL=http://localhost:9428

# --- Error reporting (Bugsink) ---
# Create a project in Bugsink (http://localhost:8000), then paste its DSN here.
# Left blank, the app still boots; error reporting is simply disabled.
SENTRY_DSN=

# --- External APIs (optional; a keyless clone still boots) ---
# Anthropic (Claude Haiku classification) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Tavily search — https://app.tavily.com/home
TAVILY_API_KEY=
# BrandFetch — https://brandfetch.com/
BRANDFETCH_API_KEY=
BRANDFETCH_CLIENT_ID=
# Google Programmable Search (company context) — https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CX=
