{% extends "layout.njk" %}

{% block title %}Breakbeat — Jobs{% endblock %}

{% block content %}

<section>
  <h2 style="margin-top:0">New search</h2>

  {% if error %}
    <p style="color:#9b1c1c; background:#fde8e8; border:1px solid #f5a0a0; padding:0.6rem 0.9rem; border-radius:4px;">
      {{ error }}
    </p>
  {% endif %}

  <form method="POST" action="/" style="display:flex; flex-direction:column; gap:0.75rem; max-width:500px;">
    <div>
      <label for="name" style="display:block; font-weight:600; margin-bottom:0.25rem;">Company name</label>
      <input
        type="text"
        id="name"
        name="name"
        value="{{ fields.name if fields else '' }}"
        placeholder="Acme Corp"
        maxlength="200"
        style="width:100%; padding:0.4rem 0.6rem; border:1px solid #ccc; border-radius:4px; font-size:1rem;"
      />
    </div>
    <div>
      <label for="url" style="display:block; font-weight:600; margin-bottom:0.25rem;">Homepage URL</label>
      <input
        type="url"
        id="url"
        name="url"
        value="{{ fields.url if fields else '' }}"
        placeholder="https://acme.com"
        style="width:100%; padding:0.4rem 0.6rem; border:1px solid #ccc; border-radius:4px; font-size:1rem;"
      />
      <p style="font-size:0.8rem; color:#555; margin:0.25rem 0 0;">Provide the URL for unambiguous results.</p>
    </div>
    <div>
      <button type="submit" style="padding:0.5rem 1.25rem; background:#0066cc; color:#fff; border:none; border-radius:4px; font-size:1rem; cursor:pointer;">
        Start search
      </button>
    </div>
  </form>
</section>

<section>
  <h2>Recent jobs</h2>

  {% if jobs | length == 0 %}
    <p style="color:#555;">No jobs yet. Start a search above.</p>
  {% else %}
    <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
      <thead>
        <tr style="text-align:left; border-bottom:2px solid #ddd;">
          <th style="padding:0.5rem 0.5rem 0.5rem 0;">Company</th>
          <th style="padding:0.5rem;">Status</th>
          <th style="padding:0.5rem;">Results</th>
          <th style="padding:0.5rem;">Started</th>
        </tr>
      </thead>
      <tbody>
        {% for job in jobs %}
          <tr style="border-bottom:1px solid #eee;">
            <td style="padding:0.5rem 0.5rem 0.5rem 0;">
              <a href="/{{ job.id }}">{{ job.company_name }}</a>
            </td>
            <td style="padding:0.5rem;">
              {% if job.status == 'failed' %}
                <span class="badge badge-fail">{{ job.status }}</span>
              {% elif job.status == 'done' or job.status == 'done_with_warnings' %}
                <span class="badge badge-status" style="background:#d1fae5; color:#065f46; border-color:#6ee7b7;">{{ job.status }}</span>
              {% else %}
                <span class="badge badge-status">{{ job.status }}</span>
              {% endif %}
            </td>
            <td style="padding:0.5rem;">{{ job.included_count }}</td>
            <td style="padding:0.5rem; color:#555;">{{ job.created_at }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</section>

{% endblock %}
