{% extends "layout.njk" %}

{% block title %}Breakbeat — Jobs{% endblock %}

{% block content %}

<section>
  <h2 style="margin-top:0">New search</h2>

  {% if error %}
    <p style="color:#9b1c1c; background:#fde8e8; border:1px solid #f5a0a0; padding:0.6rem 0.9rem; border-radius:4px;">
      {{ error }}
    </p>
  {% endif %}

  <form method="POST" action="/" style="display:flex; flex-direction:column; gap:0.75rem; max-width:500px;">
    <div>
      <label for="name" style="display:block; font-weight:600; margin-bottom:0.25rem;">Company name</label>
      <input
        type="text"
        id="name"
        name="name"
        value="{{ fields.name if fields else '' }}"
        placeholder="Acme Corp"
        maxlength="200"
        style="width:100%; padding:0.4rem 0.6rem; border:1px solid #ccc; border-radius:4px; font-size:1rem;"
      />
    </div>
    <div>
      <label for="url" style="display:block; font-weight:600; margin-bottom:0.25rem;">Homepage URL</label>
      <input
        type="url"
        id="url"
        name="url"
        value="{{ fields.url if fields else '' }}"
        placeholder="https://acme.com"
        style="width:100%; padding:0.4rem 0.6rem; border:1px solid #ccc; border-radius:4px; font-size:1rem;"
      />
      <p style="font-size:0.8rem; color:#555; margin:0.25rem 0 0;">Provide the URL for unambiguous results.</p>
    </div>
    <div>
      <button type="submit" style="padding:0.5rem 1.25rem; background:#0066cc; color:#fff; border:none; border-radius:4px; font-size:1rem; cursor:pointer;">
        Start search
      </button>
    </div>
  </form>
</section>

<section>
  <h2>Recent jobs</h2>

  {% include "_jobs_list.njk" %}
</section>

{% endblock %}
