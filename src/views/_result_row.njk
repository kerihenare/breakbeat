{#
  _result_row.njk — a single result row partial.
  Receives: row (ResultRow)
  NOTE: | safe is NOT used. All output is auto-escaped.
#}
<article style="padding:0.65rem 0; border-bottom:1px solid #eee;">
  <div style="display:flex; align-items:baseline; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.25rem;">
    <a href="{{ row.url }}" target="_blank" rel="noopener noreferrer" style="font-weight:600;">
      {{ row.title }}
    </a>
    {% if row.confidence == 'low' %}
      <span class="badge badge-low">low confidence</span>
    {% endif %}
    {% if not row.published_date %}
      <span class="badge badge-date">date unknown</span>
    {% endif %}
  </div>
  <div style="font-size:0.8rem; color:#555; display:flex; gap:0.75rem; flex-wrap:wrap; margin-bottom:0.3rem;">
    <span>{{ row.source_domain }}</span>
    {% if row.published_date %}
      <span>{{ row.published_date }}</span>
    {% endif %}
  </div>
  {% if row.snippet %}
    <p style="margin:0; font-size:0.875rem; color:#333; line-height:1.45;">{{ row.snippet }}</p>
  {% endif %}
</article>
